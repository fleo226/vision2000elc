// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Soumissions de formulaires (contact + devis traduction)
model Submission {
  id         String   @id @default(cuid())
  type       String   // "contact" | "quote" | "formation"
  name       String
  email      String
  phone      String?
  // Champs spécifiques au contact
  subject    String?
  message    String?
  // Champs spécifiques au devis traduction
  sourceLang String?
  targetLang String?
  wordCount  Int?
  docType    String?
  delivery   String?
  estimatedPrice Int?
  // Champs spécifiques à l'inscription formation
  formation  String?
  // Statut de traitement
  status     String   @default("new") // "new" | "read" | "replied" | "archived"
  // Métadonnées
  createdAt  DateTime @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([type])
  @@index([status])
  @@index([createdAt])
}
