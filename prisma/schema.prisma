// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Soumissions de formulaires (contact + devis traduction)
model Submission {
  id         String   @id @default(cuid())
  type       String   // "contact" | "quote" | "formation"
  name       String
  email      String
  phone      String?
  // Champs spécifiques au contact
  subject    String?
  message    String?
  // Champs spécifiques au devis traduction
  sourceLang String?
  targetLang String?
  wordCount  Int?
  docType    String?
  delivery   String?
  estimatedPrice Int?
  // Champs spécifiques à l'inscription formation
  formation  String?
  // Statut de traitement
  status     String   @default("new") // "new" | "read" | "replied" | "archived"
  // Métadonnées
  createdAt  DateTime @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([type])
  @@index([status])
  @@index([createdAt])
}

// Visites de pages (analytics)
model Visit {
  id        String   @id @default(cuid())
  sessionId String   // identifie une session utilisateur
  path      String   // chemin de la page visitée (ex: "/formations")
  referrer  String?  // page précédente (source)
  userAgent String?  // navigateur/appareil
  language  String?  // langue du navigateur
  duration  Int      @default(0) // durée en secondes (mis à jour à la sortie)
  enteredAt DateTime @default(now()) // moment d'entrée sur la page
  exitedAt  DateTime? // moment de sortie

  @@index([sessionId])
  @@index([path])
  @@index([enteredAt])
}

// Clics sur éléments (analytics)
model Click {
  id        String   @id @default(cuid())
  sessionId String   // identifie la session
  path      String   // page où le clic a eu lieu
  element   String   // type d'élément cliqué (ex: "cta-devis", "whatsapp", "phone")
  label     String?  // texte ou label du bouton
  href      String?  // lien destination si applicable
  timestamp DateTime @default(now())

  @@index([sessionId])
  @@index([path])
  @@index([element])
  @@index([timestamp])
}
